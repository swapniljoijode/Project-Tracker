# Project Tracker — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real credentials.

# ── Datastore ─────────────────────────────────────────────────────────────────
# Neon Postgres connection string (from https://console.neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Tracker API ───────────────────────────────────────────────────────────────
# Secret token that protects write endpoints.
# Generate with: openssl rand -hex 32
TRACKER_API_TOKEN=change_me

# ── Next.js ───────────────────────────────────────────────────────────────────
# Public base URL of the deployed tracker (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── CLI ───────────────────────────────────────────────────────────────────────
# Base URL the CLI sends requests to. Mirrors NEXT_PUBLIC_APP_URL in production.
TRACKER_API_URL=http://localhost:3000
